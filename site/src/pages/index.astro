---
import '../styles/marketing.css';

const github = 'https://github.com/stephnangue/warden';
const nav = [
  { label: 'Use cases', href: '/use-cases/' },
  { label: 'Providers', href: '/provider-backends/' },
  { label: 'Docs', href: '/concepts/' },
  { label: 'GitHub', href: github },
];
const useCases = [
  {
    n: '01',
    h: 'Access brokering',
    p: 'Warden holds the upstream secret and injects a scoped, short-lived credential into each request. The agent presents only its own identity and never holds a key — no per-system credential sprawl.',
  },
  {
    n: '02',
    h: 'Breach containment',
    p: 'A prompt-injected, jailbroken, or otherwise compromised agent has nothing to exfiltrate, because it never holds a credential. One bad step stays a contained, recoverable event.',
  },
  {
    n: '03',
    h: 'Runtime authorization',
    p: 'Every call is authorized the moment it happens — down to the action and its arguments, and for MCP, down to which tools an agent may invoke and which arguments it may pass.',
  },
  {
    n: '04',
    h: 'Centralized governance',
    p: 'One control plane for every system an agent touches: one identity, one policy surface, and one audit log across clouds, code hosts, observability, databases, SaaS, and MCP servers.',
  },
  {
    n: '05',
    h: 'Audit & attribution',
    p: 'Every request tied to the real identity behind it, the role used, the policy decision, and the upstream called — with secrets never written to the log in the clear.',
  },
];
const systems = [
  { h: 'MCP servers', p: 'GitHub, Google Cloud, Slack, Cloudflare, AWS (SigV4), and any generic MCP server — with tool-level policy.' },
  { h: 'LLM APIs', p: 'Anthropic, OpenAI, Mistral, Cohere.' },
  { h: 'Cloud infrastructure', p: 'AWS, Azure, GCP, Alicloud, IBM Cloud, OVH, Scaleway, Cloudflare.' },
  { h: 'Code hosting & CI/CD', p: 'GitHub, GitLab, Atlassian, Ansible Tower, Terraform Enterprise.' },
  { h: 'Observability', p: 'Datadog, Grafana, Prometheus, Splunk, Sentry, New Relic, Dynatrace, Elastic, Honeycomb.' },
  { h: 'Incident & ITSM', p: 'PagerDuty, ServiceNow, Slack.' },
  { h: 'Kubernetes & secrets', p: 'Kubernetes service-account tokens, and short-lived tokens from HashiCorp Vault / OpenBao.' },
  { h: 'Databases', p: 'AWS RDS / Aurora and Redshift, via IAM database auth tokens.' },
];
const auth = [
  { h: 'JWT', p: 'A signed token Warden validates before swapping in the real upstream credential.' },
  { h: 'TLS certificate', p: 'An X.509 client certificate, proven at the TLS handshake or forwarded by a terminating proxy.' },
  { h: 'SPIFFE', p: "An X.509-SVID or JWT-SVID verified against the trust domain's bundle, with federation." },
  { h: 'Kubernetes', p: "A ServiceAccount token validated through the issuing cluster's TokenReview API." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Warden — the secure gateway for AI agents</title>
    <meta
      name="description"
      content="The secure gateway connecting AI agents to the enterprise systems they need to do real work. One control plane for identity, policy, and audit."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href="https://wardengateway.com/" />
    <meta property="og:title" content="Warden — the secure gateway for AI agents" />
    <meta
      property="og:description"
      content="The secure gateway connecting AI agents to the enterprise systems they need to do real work."
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Warden" />
    <meta property="og:url" content="https://wardengateway.com/" />
    <meta property="og:image" content="https://wardengateway.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Warden — the secure gateway for AI agents" />
    <meta
      name="twitter:description"
      content="The secure gateway connecting AI agents to the enterprise systems they need to do real work."
    />
    <meta name="twitter:image" content="https://wardengateway.com/og.png" />
  </head>
  <body>
    <header class="nav">
      <div class="wrap nav-inner">
        <a class="nav-logo" href="/"><img src="/logo-light.svg" alt="Warden" /></a>
        <nav class="nav-links">
          {nav.map((l) => <a href={l.href}>{l.label}</a>)}
        </nav>
        <div class="nav-spacer"></div>
        <div class="nav-cta">
          <a class="btn btn-primary" href="/concepts/">Get started</a>
        </div>
      </div>
    </header>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="wrap hero-inner">
          <div>
            <p class="eyebrow">Identity · Policy · Audit</p>
            <h1>The secure gateway for AI agents.</h1>
            <p class="sub">
              Agents present only their own identity. Warden brokers every connection —
              injecting real credentials, enforcing policy on every call, and tying it all to
              one audit log. Across every MCP server, cloud, code host, database, and SaaS.
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary" href="/concepts/">Get started</a>
              <a class="btn btn-on-dark" href={github}>View on GitHub</a>
            </div>
            <p class="hero-note">Open source · MPL-2.0 · OpenBao integrator</p>
          </div>

          <div class="hero-visual">
            <svg class="flow" viewBox="0 0 340 366" role="img" aria-label="An AI agent presents only its identity to Warden, which injects real credentials and proxies the request to upstream systems.">
              <defs>
                <marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto">
                  <path d="M0 0 L10 5 L0 10 z" fill="#cdd4e6" />
                </marker>
              </defs>
              <rect class="box" x="60" y="14" width="220" height="72" rx="12" />
              <text class="t" x="170" y="46">AI Agent</text>
              <text class="s" x="170" y="66">presents only its identity</text>

              <line class="line" x1="170" y1="90" x2="170" y2="142" marker-end="url(#ar)" />
              <text class="e" x="196" y="120" style="text-anchor:start">identity only</text>

              <rect class="box box-warden" x="60" y="146" width="220" height="84" rx="14" />
              <text class="t t-warden" x="170" y="182">Warden</text>
              <text class="s" x="170" y="204">authenticate · authorize · inject</text>

              <line class="line" x1="170" y1="234" x2="170" y2="286" marker-end="url(#ar)" />
              <text class="e" x="196" y="264" style="text-anchor:start">real credentials</text>

              <rect class="box" x="60" y="290" width="220" height="72" rx="12" />
              <text class="t" x="170" y="322">Upstreams</text>
              <text class="s" x="170" y="342">MCP · Cloud · LLMs · Code · SaaS</text>
            </svg>
            <div class="cap">
              <div class="chip">Identity <span>✓</span></div>
              <div class="chip">Policy <span>✓</span></div>
              <div class="chip">Audit <span>✓</span></div>
            </div>
          </div>
        </div>
      </section>

      <!-- Positioning strip -->
      <section class="band">
        <div class="wrap">
          <div class="section-head">
            <p class="kicker">The problem</p>
            <h2 class="h">The control gap, not the credential, is the headline</h2>
            <p class="lead">
              Pointing an agent at production means handing it over-scoped, long-lived
              credentials, with no per-request policy and no identity-tied audit. MCP makes it
              acute — a dozen tools become a dozen static secrets in a dozen processes, none
              rotating, none governed.
            </p>
          </div>
          <div class="proof">
            <div class="item">
              <h3><b>Identity</b> the agent owns</h3>
              <p>A JWT, TLS client certificate, SPIFFE SVID, or Kubernetes token. The agent holds no upstream secret — ever.</p>
            </div>
            <div class="item">
              <h3><b>Policy</b> at request time</h3>
              <p>Every call evaluated the moment it happens — action, arguments, caller IP, time, and on whose behalf.</p>
            </div>
            <div class="item">
              <h3><b>Audit</b> tied to the caller</h3>
              <p>Every request attributed to the real identity, role, decision, and upstream — secrets never logged in clear.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- How it works -->
      <section>
        <div class="wrap">
          <div class="section-head">
            <p class="kicker">How it works</p>
            <h2 class="h">Warden sits in the request path</h2>
            <p class="lead">
              The agent points at Warden as if it were the upstream. Existing SDK code keeps
              working — only the base URL changes.
            </p>
          </div>
          <div class="steps">
            <div class="step">
              <div class="n">1</div>
              <h3>Authenticate</h3>
              <p>Warden verifies the identity the agent presents — no long-lived key in the agent's environment.</p>
            </div>
            <div class="step">
              <div class="n">2</div>
              <h3>Authorize</h3>
              <p>The call is evaluated against policy at request time, down to the action and its arguments.</p>
            </div>
            <div class="step">
              <div class="n">3</div>
              <h3>Inject & proxy</h3>
              <p>Warden injects the real, short-lived upstream credential and streams the response back unchanged.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Use cases -->
      <section class="band">
        <div class="wrap">
          <div class="section-head">
            <p class="kicker">Use cases</p>
            <h2 class="h">Five things Warden does — all at once</h2>
          </div>
          <div class="grid">
            {useCases.map((u) => (
              <div class="card">
                <div class="num">{u.n}</div>
                <h3>{u.h}</h3>
                <p>{u.p}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Supported systems -->
      <section>
        <div class="wrap">
          <div class="section-head">
            <p class="kicker">Supported systems</p>
            <h2 class="h">One gateway in front of everything the agent reaches</h2>
          </div>
          <div class="systems">
            {systems.map((s) => (
              <div class="syscat">
                <h3>{s.h}</h3>
                <p>{s.p}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Authentication -->
      <section class="band">
        <div class="wrap">
          <div class="section-head">
            <p class="kicker">Authentication</p>
            <h2 class="h">The agent's own identity — nothing more</h2>
            <p class="lead">Whichever method you use, the identity goes in the credential slot the upstream SDK already expects.</p>
          </div>
          <div class="grid">
            {auth.map((a) => (
              <div class="card">
                <h3>{a.h}</h3>
                <p>{a.p}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Closing CTA -->
      <section class="cta">
        <div class="wrap">
          <h2>Remove every secret from the agent.</h2>
          <div class="hero-actions">
            <a class="btn btn-primary" href="/concepts/">Read the concepts guide</a>
            <a class="btn btn-on-dark" href={github}>View on GitHub</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <div>
          <img src="/logo-dark.svg" alt="Warden" />
          <p class="blurb">
            The secure gateway connecting AI agents to the enterprise systems they need to do
            real work.
          </p>
        </div>
        <div>
          <h4>Product</h4>
          <ul>
            <li><a href="/use-cases/">Use cases</a></li>
            <li><a href="/provider-backends/">Providers</a></li>
            <li><a href="/auth-methods/">Authentication</a></li>
            <li><a href="/architecture/">Architecture</a></li>
          </ul>
        </div>
        <div>
          <h4>Docs</h4>
          <ul>
            <li><a href="/concepts/">Concepts</a></li>
            <li><a href="/quickstarts/workstation/">Quickstarts</a></li>
            <li><a href="/cli/">CLI reference</a></li>
            <li><a href="/install/kubernetes/">Install</a></li>
          </ul>
        </div>
        <div>
          <h4>Project</h4>
          <ul>
            <li><a href={github}>GitHub</a></li>
            <li><a href={`${github}/releases`}>Releases</a></li>
            <li><a href={`${github}/blob/main/CONTRIBUTING.md`}>Contributing</a></li>
            <li><a href={`${github}/blob/main/LICENSE`}>License (MPL-2.0)</a></li>
          </ul>
        </div>
      </div>
      <div class="wrap footer-bottom">
        <span>© Warden — MPL-2.0 licensed.</span>
        <span>An OpenBao integrator.</span>
      </div>
    </footer>
  </body>
</html>
